# Salin file ini menjadi .env

# Gemini API key untuk fitur ringkasan.
# Dapatkan dari Google AI Studio lalu isi di bawah.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# CORS frontend React
FRONTEND_ORIGIN=http://localhost:5173

# STT
STT_SAMPLE_RATE=16000
STT_FALLBACK_TEXT=materi kuliah hari ini membahas pengenalan ucapan dan teks ke ucapan

# TTS
# pyttsx3 = library TTS lokal sesuai implementasi awal
# auto    = coba Coqui/VITS jika model tersedia, jika tidak pyttsx3
# coqui   = paksa model Coqui/VITS lokal
TTS_ENGINE=pyttsx3
TTS_RATE=150
TTS_VOLUME=1.0
